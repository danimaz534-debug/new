# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/hqszihvjqscrwdzrwbyg/settings/api
VITE_SUPABASE_URL=https://your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App Configuration
VITE_APP_NAME=VoltCart Admin Panel
VITE_APP_VERSION=1.0.0
DEFAULT_LOCALE=en

# Optional: Enable debug mode (false for production)
VITE_DEBUG_MODE=false
VITE_PRODUCTION=false

# Security: Never commit actual values to version control
# For production deployment, create .env.production with actual values
